{
  "id": "enterprise-command-center",
  "name": "企业级超级编排中心",
  "nameEn": "Enterprise Command Center",
  "version": "0.1.0",
  "description": "面向 OpenClaw 的企业级预设角色库，强调角色即契约、技能可复用、流程可治理。",
  "designPrinciples": [
    "role-as-contract",
    "prompt-and-workflow-separation",
    "tiered-authority",
    "skill-reuse-over-role-bloat",
    "governance-before-delivery"
  ],
  "organization": {
    "model": "four-layer-enterprise",
    "layers": [
      {
        "id": "L0",
        "name": "治理层",
        "nameEn": "Governance",
        "organizationalUnit": "治理与审计中心"
      },
      {
        "id": "L1",
        "name": "决策层",
        "nameEn": "Strategy",
        "organizationalUnit": "策略与指挥中心"
      },
      {
        "id": "L2",
        "name": "协调层",
        "nameEn": "Coordination",
        "organizationalUnit": "交付协调中心"
      },
      {
        "id": "L3",
        "name": "执行层",
        "nameEn": "Execution",
        "organizationalUnit": "专业执行中心"
      }
    ]
  },
  "requiresGatewayMethods": [
    "agents.create",
    "agents.update",
    "agents.files.set",
    "skills.install"
  ],
